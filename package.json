{
  "name": "mcp-fetch-server",
  "version": "1.1.2",
  "description": "MCP server and CLI for fetching web content as HTML, Markdown, plain text, JSON, or YouTube transcripts",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "zcaceres (@zachcaceres zach.dev)",
  "contributors": [
    "pwilkin (ilintar@gmail.com)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zcaceres/fetch-mcp.git"
  },
  "homepage": "https://github.com/zcaceres/fetch-mcp#readme",
  "bugs": {
    "url": "https://github.com/zcaceres/fetch-mcp/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts src/cli.ts --outdir dist --target node --external jsdom --external @mozilla/readability --external turndown",
    "prepublishOnly": "bun run build",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "publish:npm": "bun run build && bun test && npm publish"
  },
  "bin": {
    "mcp-fetch-server": "dist/index.js",
    "mcp-fetch": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "fetch",
    "web",
    "scrape",
    "markdown",
    "youtube",
    "transcript"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^28.1.0",
    "private-ip": "^3.0.2",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.0",
    "@types/mozilla__readability": "^0.4.2",
    "@types/turndown": "^5.0.6"
  }
}
